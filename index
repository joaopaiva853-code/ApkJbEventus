<script>
  (() => {
    const state = {
      produtos: [],
      clientes: [],
      fornecedores: [],
      vendas: [],
      compras: [],
      notas: []
    };
    const STORAGE_MAP = {
      produtos: 'neon_produtos',
      clientes: 'neon_clientes',
      fornecedores: 'neon_fornecedores',
      vendas: 'neon_vendas',
      compras: 'neon_compras',
      notas: 'neon_notas'
    };

    const $ = (sel) => document.querySelector(sel);
    const $$ = (sel) => document.querySelectorAll(sel);
    const formatMoney = (v) => v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    const now = () => new Date().toLocaleString();

    let dashVendasVisible = true;
    let dashComprasVisible = true;
    let dashLucroVisible = true;

    function save() {
      for (const [key, storageKey] of Object.entries(STORAGE_MAP)) {
        localStorage.setItem(storageKey, JSON.stringify(state[key]));
      }
    }
    function load() {
      for (const [key, storageKey] of Object.entries(STORAGE_MAP)) {
        const raw = localStorage.getItem(storageKey);
        state[key] = raw ? JSON.parse(raw) : [];
      }
      if (!state.produtos.length && !state.clientes.length && !state.fornecedores.length &&
          !state.vendas.length && !state.compras.length && !state.notas.length) {
        state.produtos.push({ id: 1001, nome: 'Notebook Ultra', preco: 3450 }, { id: 1002, nome: 'Mouse Gamer', preco: 129.9 });
        state.clientes.push({ id: 2001, nome: 'Cliente Exemplo', email: 'cli@email.com', whatsapp: '(11) 99999-8888', endereco: 'Rua das Flores, 123' });
        state.fornecedores.push({ id: 3001, nome: 'Fornecedor Alpha', cnpj: '12.345.678/0001-90', contato: '(11) 3456-7890' });
        state.vendas.push({ id: 4001, clienteId: 2001, clienteNome: 'Cliente Exemplo', produtoId: 1001, produtoNome: 'Notebook Ultra', quantidade: 1, precoUnit: 3450, dataStr: now() });
        state.compras.push({ id: 5001, fornecedorId: 3001, fornecedorNome: 'Fornecedor Alpha', produto: 'Placa-mãe', quantidade: 5, precoUnit: 320, dataStr: now() });
        state.notas.push({ id: 6001, texto: 'App Degradê completo!', data: now() });
        save();
      }
    }

    function updateTotals() {
      const totalVendas = state.vendas.reduce((s, v) => s + v.quantidade * v.precoUnit, 0);
      const totalCompras = state.compras.reduce((s, c) => s + c.quantidade * c.precoUnit, 0);
      const lucro = totalVendas - totalCompras;

      const vendasEl = $('#dashVendas');
      const comprasEl = $('#dashCompras');
      const lucroEl = $('#dashLucro');
      if (!vendasEl || !comprasEl || !lucroEl) return;

      vendasEl.textContent = dashVendasVisible ? formatMoney(totalVendas) : 'R$ ••••••';
      comprasEl.textContent = dashComprasVisible ? formatMoney(totalCompras) : 'R$ ••••••';
      lucroEl.textContent = dashLucroVisible ? formatMoney(lucro) : 'R$ ••••••';

      $('#toggleDashVendas').textContent = dashVendasVisible ? '👁️' : '🔒';
      $('#toggleDashCompras').textContent = dashComprasVisible ? '👁️' : '🔒';
      $('#toggleDashLucro').textContent = dashLucroVisible ? '👁️' : '🔒';

      lucroEl.style.color = dashLucroVisible ? (lucro >= 0 ? '#6ee7b7' : '#fca5a5') : '#e9d5ff';

      const max = Math.max(totalVendas, totalCompras, 1);
      document.getElementById('barVendas').style.height = (totalVendas / max * 120) + 'px';
      document.getElementById('barCompras').style.height = (totalCompras / max * 120) + 'px';
    }

    function renderAll() {
      updateTotals();
    }

