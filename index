          document.getElementById('fornecedorContatoPopup').value = '';
        } else if(btn.classList.contains('delete-btn')){
          const id = parseInt(btn.dataset.id);
          if(confirm('Excluir fornecedor?')){ fornecedores = fornecedores.filter(x => x.id!==id); save(); renderFornecedores(); }
        } else if(btn.classList.contains('edit-btn')){
          const id = parseInt(btn.dataset.id);
          const f = fornecedores.find(x => x.id===id);
          if(f){
            const novoNome = prompt('Nome:', f.nome); if(novoNome===null) return;
            const novoCnpj = prompt('CNPJ:', f.cnpj); if(novoCnpj===null) return;
            const novoContato = prompt('Contato:', f.contato); if(novoContato===null) return;
            f.nome = novoNome.trim() || f.nome;
            f.cnpj = novoCnpj.trim() || f.cnpj;
            f.contato = novoContato.trim() || f.contato;
            save(); renderFornecedores();
          }
        }
      });
      renderFornecedores();`;

    // --- ANOTAÇÕES ---
    const anotacoesHTML = `
      <div class="card">
        <h2>📝 Anotações</h2>
        <div class="form-row">
          <textarea id="textoNotaPopup" rows="2" placeholder="Digite sua nota..." style="flex:1;"></textarea>
          <button id="addNotaBtnPopup">➕ Salvar</button>
        </div>
        <div id="notesContainerPopup"></div>
      </div>`;
    const anotacoesScript = `
      const STORAGE_KEY = 'neon_notas';
      const escapeHtml = s => s ? String(s).replace(/[&<>]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[m])) : '';
      const now = () => new Date().toLocaleString();
      const uid = () => Date.now() + Math.floor(Math.random()*1000);
      let notas = JSON.parse(localStorage.getItem(STORAGE_KEY)||'[]');
      function save(){ localStorage.setItem(STORAGE_KEY, JSON.stringify(notas)); }
      function renderNotas(){
        const cont = document.getElementById('notesContainerPopup');
        if(!notas.length){ cont.innerHTML = '<div style="color:#c4b5fd;">Sem anotações.</div>'; return; }
        cont.innerHTML = notas.map(n => '<div class="note-card"><div>'+escapeHtml(n.texto)+'<br><small style="color:#a78bfa;">'+n.data+'</small></div><div><button class="edit-btn" data-id="'+n.id+'">✏️ Editar</button> <button class="delete-btn" data-id="'+n.id+'">🗑️</button></div></div>').join('');
      }
      document.body.addEventListener('click', e => {
        const btn = e.target.closest('button');
        if(!btn) return;
        if(btn.id==='addNotaBtnPopup'){
          const texto = document.getElementById('textoNotaPopup').value.trim();
          if(!texto) return;
          notas.push({ id:uid(), texto, data:now() });
          save(); renderNotas();
          document.getElementById('textoNotaPopup').value = '';
        } else if(btn.classList.contains('delete-btn')){
          const id = parseInt(btn.dataset.id);
          if(confirm('Excluir anotação?')){ notas = notas.filter(x => x.id!==id); save(); renderNotas(); }
        } else if(btn.classList.contains('edit-btn')){
          const id = parseInt(btn.dataset.id);
          const n = notas.find(x => x.id===id);
          if(n){
            const novoTexto = prompt('Editar anotação:', n.texto);
            if(novoTexto !== null){
              n.texto = novoTexto.trim() || n.texto;
              n.data = now();
              save(); renderNotas();
            }
          }
        }
      });
      renderNotas();`;

    // --- CALCULADORA COM BOTÕES CENTRALIZADOS ---
    const calcHTML = `
      <div class="card" style="padding:0; background:transparent; box-shadow:none; border:none;">
        <h2>🧮 Calculadora</h2>
        <div class="calc-panel">
          <div class="calc-screen" id="calcDisplay">0</div>
          <div class="calc-buttons" id="calcButtons"></div>
        </div>
      </div>`;
    const calcScript = `
      const btns = ['C','(',')','/','7','8','9','*','4','5','6','-','1','2','3','+','0','.','⌫','='];
      document.getElementById('calcButtons').innerHTML = btns.map(b => '<button data-calc="'+b+'">'+b+'</button>').join('');
      let calcExpr = '0';
      const disp = document.getElementById('calcDisplay');

      function calcAction(val) {
        if (val === 'C') { calcExpr = '0'; disp.textContent = calcExpr; return; }
        if (val === '⌫') { calcExpr = (calcExpr.length === 1 || calcExpr === '0') ? '0' : calcExpr.slice(0, -1); disp.textContent = calcExpr; return; }
        if (val === '=') {
          try {
            const expr = calcExpr.replace(/×/g,'*').replace(/÷/g,'/');
            const res = Function('"use strict";return ('+expr+')')();
            if (isNaN(res) || !isFinite(res)) throw new Error();
            calcExpr = String(parseFloat(res.toFixed(8)));
            disp.textContent = calcExpr;
          } catch (e) { disp.textContent = 'Erro'; setTimeout(() => { calcExpr = '0'; disp.textContent = '0'; }, 800); }
          return;
        }
        if (calcExpr === '0' && /[0-9]/.test(val) && val !== '.') calcExpr = val;
        else if (calcExpr === 'Erro') calcExpr = val;
        else calcExpr += val;
        disp.textContent = calcExpr;
      }

      document.querySelectorAll('#calcButtons button').forEach(btn => {
        btn.addEventListener('click', () => calcAction(btn.dataset.calc));
      });
    `;

    // ========== INICIALIZAÇÃO ==========
    function init() {
      load();
      renderAll();

      window.addEventListener('storage', () => {
        load();
        renderAll();
      });

      $$('.nav-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const tab = btn.dataset.tab;
          if (tab === 'vendas') {
            openExternalWindow('Vendas', '🏷️', vendasHTML, vendasScript);
            return;
          }
          if (tab === 'produtos') {
            openExternalWindow('Produtos', '📦', produtosHTML, produtosScript);
            return;
          }
          if (tab === 'compras') {
            openExternalWindow('Compras', '🛒', comprasHTML, comprasScript);
            return;
          }
          if (tab === 'clientes') {
            openExternalWindow('Clientes', '👥', clientesHTML, clientesScript);
            return;
          }
          if (tab === 'fornecedores') {
            openExternalWindow('Fornecedores', '🏭', fornecedoresHTML, fornecedoresScript);
            return;
          }
          if (tab === 'anotacoes') {
            openExternalWindow('Anotações', '📝', anotacoesHTML, anotacoesScript);
            return;
          }
          if (tab === 'calc') {
            openExternalWindow('Calculadora', '🧮', calcHTML, calcScript);
            return;
          }
          // Dashboard
          $$('.nav-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          $$('.tab-pane').forEach(p => p.classList.remove('active-pane'));
          const pane = document.getElementById('dashboardPane');
          if (pane) pane.classList.add('active-pane');
        });
      });

      // Olhos mágicos
      $('#toggleDashVendas').addEventListener('click', () => { dashVendasVisible = !dashVendasVisible; updateTotals(); });
      $('#toggleDashCompras').addEventListener('click', () => { dashComprasVisible = !dashComprasVisible; updateTotals(); });
      $('#toggleDashLucro').addEventListener('click', () => { dashLucroVisible = !dashLucroVisible; updateTotals(); });
    }

    init();
  })();
</script>
</body>
</html>                                                               